    "@monaco-editor/react": "^4.6.0",
    "@tauri-apps/api": "^2.0.0",
    "@xyflow/react": "^12.10.2",
    "ag-grid-community": "^35.2.1",
    "ag-grid-react": "^35.2.1",
    "antd": "^6.3.5",
    "monaco-editor": "^0.45.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hotkeys-hook": "^5.2.4",
    "zustand": "^4.4.7"
